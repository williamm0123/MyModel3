{
  "comment": "Merged MVSFormer++ configuration (high-memory profile for 2xV100 32GB)",
  "mode": "train",

  "datapath": "${DATA_ROOT}/dataset/DTU/dtu_training/",
  "train_data_list": "lists/dtu/train.txt",
  "val_data_list": "lists/dtu/test.txt",
  "all_views": "49",
  "light_mode": "A",
  "views": [0, 1, 2, 3],

  "train": {
    "epochs": 16,
    "batch_size": 2,
    "num_workers": 4,
    "lr": 1e-4,
    "weight_decay": 0.01,
    "lr_scheduler": "cosine",
    "warmup_steps": 500,
    "lr_min_ratio": 0.01,
    "short_cosine_steps": 2000,
    "short_cosine_lr_floor": 0.2,
    "short_cosine_warmup_ratio": 0.1,
    "persistent_workers": true,
    "use_amp": true,
    "log_interval": 50,
    "save_interval": 1,
    "eval_interval": 1,
    "grad_clip": 1.0
  },

  "loss": {
    "depth_types": ["ce", "ce", "ce", "ce"],
    "loss_weights": [1.0, 1.0, 1.0, 1.0],
    "clip_func": "dynamic"
  },

  "fpn": {
    "comment": "FPN channel config: [stage4, stage3, stage2, stage1]",
    "feat_chs": [8, 16, 32, 64],
    "fpn_out_ch": 64
  },

  "dinov3": {
    "weights": "${DATA_ROOT}/dataset/DINOv3/pre_trained/dinov3_vitb16_pretrain_lvd1689m-73cec8be.pth",
    "arch": "dinov3_vitb16",
    "patch_size": 16,
    "input_scale": 1.0,
    "vit_ch": 768,
    "use_imagenet_norm": true,
    "pick_layers": [3, 7, 11],
    "scales": [1, 0.5, 0.25, 0.125],
    "freeze": true
  },

  "sva": {
    "comment": "Side View Attention (CrossVITDecoder)",
    "dim": 768,
    "num_heads": 12,
    "mlp_ratio": 4.0,
    "cross_interval_layers": 3,
    "init_values": 1.0,
    "prev_values": 0.5,
    "post_norm": false,
    "pre_norm_query": true,
    "no_combine_norm": false,
    "use_als": true,
    "init_als": 0.5,
    "num_stage2_blocks": 2,
    "pe_max_hw": [128, 128]
  },

  "fmt": {
    "comment": "Feature Matching Transformer",
    "nhead": 4,
    "mlp_ratio": 4.0,
    "init_values": 1.0,
    "layer_names": ["self", "cross", "self", "cross"]
  },

  "depth": {
    "comment": "Multi-stage depth estimation config",
    "ndepths": [32, 16, 8, 4],
    "base_chs": [64, 32, 16, 8],
    "depth_interval_ratios": [4.0, 2.67, 1.5, 1.0],
    "inverse_depth": true,
    "depth_type": "ce",
    "temperatures": [5.0, 5.0, 5.0, 1.0]
  },

  "dataset": {
    "rectified_dir": "Rectified_raw",
    "resize_hw": [512, 640]
  },

  "output": {
    "runs_dir": "../log"
  }
}
